# ──────────────────────────────────────────────────────────────────────────────
# InterviewIQ — environment variables
#
# Copy this file to `.env` and fill in the values:
#   cp .env.example .env
#
# Conventions:
#   • Variables prefixed NEXT_PUBLIC_ are exposed to the browser. Never put
#     secrets in them.
#   • Everything else is server-only and must be kept secret.
#   • Never commit `.env` — only this `.env.example` belongs in git.
# ──────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# 1) SUPABASE — Postgres + Auth + Realtime
#    Dashboard → Project Settings → API
# ══════════════════════════════════════════════════════════════════════════════

# Project URL (public, used by browser and server Supabase clients).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Anon/public API key (public; access is limited by Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service-role key (SECRET — bypasses RLS; server-only, used for privileged
# operations such as writing transcript segments).
SUPABASE_SERVICE_ROLE_KEY="eyJ..."


# ══════════════════════════════════════════════════════════════════════════════
# 2) DATABASE — Prisma connection strings
#    Dashboard → Project Settings → Database → Connection string
#
#    DATABASE_URL  → pooled connection (port 6543, pgbouncer) used at runtime.
#    DIRECT_URL    → direct connection (port 5432) used by Prisma for
#                    migrations / `db push`.
# ══════════════════════════════════════════════════════════════════════════════

DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"


# ══════════════════════════════════════════════════════════════════════════════
# 3) LIVEKIT — WebRTC video rooms
#    https://cloud.livekit.io → Project → Settings → Keys
#    (or your self-hosted LiveKit server)
# ══════════════════════════════════════════════════════════════════════════════

# WebSocket URL of your LiveKit project (public — the browser connects to it).
NEXT_PUBLIC_LIVEKIT_URL="wss://YOUR-PROJECT.livekit.cloud"

# API key + secret (SECRET — server-only, used to mint room access tokens).
LIVEKIT_API_KEY="APIxxxxxxxxxxxx"
LIVEKIT_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ══════════════════════════════════════════════════════════════════════════════
# 4) LLM — follow-up suggestions, question generation, final evaluation
#    Any OpenAI-compatible chat-completions endpoint works:
#      • Groq (default):  https://api.groq.com/openai/v1
#      • OpenAI:          https://api.openai.com/v1
#      • Ollama (local):  http://localhost:11434/v1
#    Get a free Groq key at https://console.groq.com
# ══════════════════════════════════════════════════════════════════════════════

# SECRET — required (no default).
LLM_API_KEY="gsk_..."

# Optional — defaults shown.
LLM_API_URL="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.3-70b-versatile"


# ══════════════════════════════════════════════════════════════════════════════
# 5) WHISPER — speech-to-text for the live transcript
#    Any OpenAI-compatible /audio/transcriptions endpoint works
#    (Groq, OpenAI, or a self-hosted faster-whisper server).
#    All three are OPTIONAL: WHISPER_API_KEY falls back to LLM_API_KEY, and the
#    URL/model default to Groq + whisper-large-v3.
# ══════════════════════════════════════════════════════════════════════════════

# WHISPER_API_KEY="gsk_..."
# WHISPER_API_URL="https://api.groq.com/openai/v1"
# WHISPER_MODEL="whisper-large-v3"
